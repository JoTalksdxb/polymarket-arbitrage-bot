# Private key that signs CLOB orders (64 hex characters; 0x prefix is optional).
POLYMARKET_PRIVATE_KEY=

# Polymarket proxy / funder address (same wallet you fund on Polymarket; 0x + 40 hex).
PROXY_WALLET_ADDRESS=

# Polygon JSON-RPC URL (Alchemy, Infura, Ankr, or another provider).
RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_API_KEY

# --- Optional (defaults match production Polymarket / Polygon) ---

# CLOB REST API base (default: https://clob.polymarket.com).
CLOB_HOST=https://clob.polymarket.com

# Chain ID for CLOB client (default: 137 Polygon mainnet).
CHAIN_ID=137

# Real-time data WebSocket (default: wss://ws-live-data.polymarket.com).
RTDS_WS_URL=wss://ws-live-data.polymarket.com

# CLOB signature type: 0 EOA, 1 EIP-1271, 2 Gnosis Safe / proxy (default: 2).
POLYMARKET_SIGNATURE_TYPE=2
